# File: .env
# Environment variables for docker-compose.yml development environment.
# Store sensitive credentials here locally and ensure this file is NOT committed to Git.
# Use defaults in docker-compose.yml for convenience if values are not set here.

# --- MySQL Settings ---
MYSQL_HOST=mysql_db
MYSQL_DATABASE=iam_db
MYSQL_USER=iam_user
# !! CHANGE THIS PASSWORD !!
MYSQL_PASSWORD=iam_password_change_me
# !! CHANGE THIS PASSWORD !!
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_PORT=3306

# --- Redis Settings ---
REDIS_HOST=redis_cache
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password # Uncomment and set if Redis requires a password

# --- MailHog Settings ---
MAILHOG_HOST=mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# --- Kafka / Zookeeper Settings ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092 # Internal Kafka address used by the application container
KAFKA_PORT=9092 # External Kafka port exposed on the host machine
ZOOKEEPER_PORT=2181

# --- JWT Secret ---
# !! CHANGE THIS SECRET (Must be Base64 encoded, >= 256 bits / 32 bytes) !!
# Generate a secure secret using: openssl rand -base64 32 (or more bytes)
SECURITY_JWT_SECRET=Z/Mf9s1rB4l+pZkCwJ8Aq7vL0Z3pDa8sCxWZqP0gN0=

# Add other environment variables for the application or services if needed
# e.g., API keys, external service URLs