# File: Env.env
# Environment variables for docker-compose.yml and application.properties development environment.
# Store sensitive credentials and environment-specific settings here locally.
# Ensure this file is NOT committed to Git.

# --- MySQL Settings ---
MYSQL_HOST=localhost
MYSQL_DATABASE=iam_db
MYSQL_USER=iam_user
# !! CHANGE THIS PASSWORD !! Must match value used in V1 migration healthcheck if not updated there too
MYSQL_PASSWORD=iam_password_change_me
# !! CHANGE THIS PASSWORD !!
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_PORT=3306

# --- Redis Settings ---
REDIS_HOST=localhost
REDIS_PORT=6379
## Set a password for Redis (recommended)
#REDIS_PASSWORD=your_strong_redis_password

# --- MailHog Settings ---
MAILHOG_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# --- Kafka / Zookeeper Settings ---
# Internal Kafka address used by the application container and other services like Kafdrop
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
# External Kafka port exposed on the host machine for external tools/clients
KAFKA_HOST_PORT=9092
ZOOKEEPER_PORT=2181
# Kafka Topic Names (Used by docker-compose to pass to consumer)
KAFKA_TOPIC_AUDIT_EVENTS=iam-audit-events
KAFKA_TOPIC_AUDIT_EVENTS_DLT=iam-audit-events.DLT

# --- JWT Secret ---
# !! CHANGE THIS SECRET (Must be Base64 encoded, >= 256 bits / 32 bytes) !!
# Generate using: openssl rand -base64 32 (or more bytes)
SECURITY_JWT_SECRET=iGiynh2rQun2PD00RN7GtpHqSL0o7fYloZ4L/fTyUBw=


# Master key for encrypting sensitive config (e.g., OAuth secrets, keystore passwords)
# MUST be Base64 encoded, 256-bit (32 bytes decoded) or stronger recommended.
APP_ENCRYPTION_KEY=bMxszoSi/nUOoKFCFrCTNy86AnVUqGM1Juyi4z+gmpU=
# --- Application Settings ---
# Base URL used for constructing links in emails (verification, password reset)
# Should point to the frontend URL usually, or backend API base if handling directly.
IAM_BASE_URL=http://localhost:8080

# Add other environment variables for the application or services if needed
# e.g., API keys, external service URLs